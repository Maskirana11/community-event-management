@page "/events"
@inject ApplicationDbContext DbContext
@using CommunityEvents.ViewModels
@rendermode InteractiveServer
@attribute [StreamRendering]

<PageTitle>All Events</PageTitle>

<div class="page-container">
    <div class="page-header">
        <div class="page-header-info">
            <h1>📅 All Events</h1>
            <p>Browse and filter community events</p>
        </div>
        <AuthorizeView Roles="Admin">
            <a class="btn btn-primary" href="events/create">➕ Create Event</a>
        </AuthorizeView>
    </div>

    <!-- Filter Bar -->
    <EditForm Model="filter" OnSubmit="ApplyFilter" class="filter-bar">
        <div class="filter-group">
            <label class="filter-label">Search</label>
            <InputText @bind-Value="filter.SearchTerm" class="form-control" placeholder="Event name..." />
        </div>
        <div class="filter-group">
            <label class="filter-label">From Date</label>
            <InputDate @bind-Value="filter.DateFrom" class="form-control" />
        </div>
        <div class="filter-group">
            <label class="filter-label">To Date</label>
            <InputDate @bind-Value="filter.DateTo" class="form-control" />
        </div>
        <div class="filter-group">
            <label class="filter-label">Venue</label>
            <InputSelect @bind-Value="filter.VenueId" class="form-control">
                <option value="">All Venues</option>
                @if (venues != null)
                {
                    @foreach (var venue in venues)
                    {
                        <option value="@venue.Id">@venue.Name</option>
                    }
                }
            </InputSelect>
        </div>
        <div class="filter-group">
            <label class="filter-label">Event Type</label>
            <InputSelect @bind-Value="filter.EventType" class="form-control">
                <option value="">All Types</option>
                @if (eventTypes != null)
                {
                    @foreach (var type in eventTypes)
                    {
                        <option value="@type">@type</option>
                    }
                }
            </InputSelect>
        </div>
        <div class="filter-group">
            <label class="filter-label">Activity Type</label>
            <InputSelect @bind-Value="filter.ActivityType" class="form-control">
                <option value="">All Activities</option>
                @if (activityTypes != null)
                {
                    @foreach (var act in activityTypes)
                    {
                        <option value="@act">@act</option>
                    }
                }
            </InputSelect>
        </div>
        <div style="display:flex; gap:8px; align-self:flex-end;">
            <button type="submit" class="btn btn-primary">🔍 Filter</button>
            <button type="button" class="btn btn-secondary" @onclick="ClearFilters">✕ Clear</button>
        </div>
    </EditForm>

    @if (events == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div style="margin-bottom:20px; color:var(--text-muted); font-size:14px;">
            Showing <strong style="color:var(--text-primary)">@events.Count</strong> event(s)
        </div>

        @if (!events.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">🎪</div>
                <div class="empty-state-title">No events found</div>
                <p>Try adjusting your filters or create a new event.</p>
                <AuthorizeView Roles="Admin">
                    <a class="btn btn-primary" href="events/create" style="margin-top:16px;">Create Event</a>
                </AuthorizeView>
            </div>
        }
        else
        {
            <div class="events-grid">
                @foreach (var ev in events)
                {
                    var daysUntil = (ev.Date - DateTime.Today).Days;
                    <div class="event-card">
                        <div class="event-card-header">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                                <span class="event-type-badge badge-@ev.EventType.ToLower()">@ev.EventType</span>
                                @if (daysUntil == 0)
                                {
                                    <span class="badge badge-confirmed">Today!</span>
                                }
                                else if (daysUntil > 0 && daysUntil <= 3)
                                {
                                    <span class="badge badge-pending">In @daysUntil day(s)</span>
                                }
                            </div>
                            <div class="event-card-title">@ev.Name</div>
                            <div class="event-card-desc">@ev.Description</div>
                        </div>
                        <div class="event-card-body">
                            <div class="event-meta">
                                <div class="event-meta-item">
                                    <span class="icon">📅</span>
                                    @ev.Date.ToString("ddd, MMM dd yyyy") &bull; @DateTime.Today.Add(ev.Time).ToString("hh:mm tt")
                                </div>
                                @if (ev.EventVenues.Any())
                                {
                                    <div class="event-meta-item">
                                        <span class="icon">📍</span>
                                        @string.Join(", ", ev.EventVenues.Select(v => v.Venue.Name))
                                    </div>
                                }
                                @if (ev.MaxCapacity.HasValue)
                                {
                                    var pct = (int)Math.Min(100, ev.Registrations.Count * 100.0 / ev.MaxCapacity.Value);
                                    <div class="event-meta-item" style="flex-direction:column; align-items:flex-start; gap:4px;">
                                        <span style="font-size:12px;">@ev.Registrations.Count / @ev.MaxCapacity capacity</span>
                                        <div class="capacity-bar" style="width:100%">
                                            <div class="capacity-fill" style="width:@pct%"></div>
                                        </div>
                                    </div>
                                }
                                @if (ev.EventActivities.Any())
                                {
                                    <div class="event-meta-item" style="flex-wrap:wrap; gap:4px;">
                                        <span class="icon">🎯</span>
                                        @foreach (var ea in ev.EventActivities.Take(3))
                                        {
                                            <span class="tag" style="margin:0;">@ea.Activity.Name</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="event-card-footer">
                            <span class="registration-count">@ev.Registrations.Count registered</span>
                            <div style="display:flex; gap:6px;">
                                <a class="btn btn-primary btn-sm" href="events/details/@ev.Id">Details</a>
                                <AuthorizeView Roles="Admin">
                                    <a class="btn btn-secondary btn-sm" href="events/edit/@ev.Id">Edit</a>
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteEvent(ev.Id)">Delete</button>
                                </AuthorizeView>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private EventFilterViewModel filter = new EventFilterViewModel();
    private List<Event>? events;
    private List<Venue>? venues;
    private List<string>? eventTypes;
    private List<string>? activityTypes;

    protected override async Task OnInitializedAsync()
    {
        venues = await DbContext.Venues.ToListAsync();
        eventTypes = await DbContext.Events.Select(e => e.EventType).Distinct().ToListAsync();
        activityTypes = await DbContext.Activities.Select(a => a.Type).Distinct().ToListAsync();
        await LoadEvents();
    }

    private async Task ApplyFilter()
    {
        await LoadEvents();
    }

    private async Task ClearFilters()
    {
        filter = new EventFilterViewModel();
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        var query = DbContext.Events
            .Include(e => e.EventVenues).ThenInclude(ev => ev.Venue)
            .Include(e => e.EventActivities).ThenInclude(ea => ea.Activity)
            .Include(e => e.Registrations)
            .Where(e => e.IsActive)
            .AsQueryable();

        if (!string.IsNullOrWhiteSpace(filter.SearchTerm))
            query = query.Where(e => e.Name.Contains(filter.SearchTerm) || e.Description.Contains(filter.SearchTerm));

        if (filter.DateFrom.HasValue)
            query = query.Where(e => e.Date >= filter.DateFrom.Value);

        if (filter.DateTo.HasValue)
            query = query.Where(e => e.Date <= filter.DateTo.Value);

        if (filter.VenueId.HasValue)
            query = query.Where(e => e.EventVenues.Any(ev => ev.VenueId == filter.VenueId.Value));

        if (!string.IsNullOrWhiteSpace(filter.ActivityType))
            query = query.Where(e => e.EventActivities.Any(ea => ea.Activity.Type == filter.ActivityType));

        if (!string.IsNullOrWhiteSpace(filter.EventType))
            query = query.Where(e => e.EventType == filter.EventType);

        events = await query.OrderBy(e => e.Date).ToListAsync();
    }

    private async Task DeleteEvent(int id)
    {
        var ev = await DbContext.Events.FindAsync(id);
        if (ev != null)
        {
            DbContext.Events.Remove(ev);
            await DbContext.SaveChangesAsync();
            await LoadEvents();
        }
    }
}
