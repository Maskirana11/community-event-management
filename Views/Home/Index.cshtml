@model CommunityEvents.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Hero -->
<div class="hero">
    <div class="hero-title">Welcome to Community Events 🎉</div>
    <div class="hero-subtitle">Create memorable experiences and bring your community together.</div>
    <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a class="btn btn-primary btn-lg" asp-controller="Events" asp-action="Index">Browse Events</a>
        <a class="btn btn-secondary btn-lg" asp-controller="Events" asp-action="Create">Create Event</a>
    </div>
</div>

<div class="page-container">
    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon purple">📅</div>
            <div>
                <div class="stat-value">@Model.TotalEvents</div>
                <div class="stat-label">Total Events</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">🚀</div>
            <div>
                <div class="stat-value">@Model.UpcomingEvents</div>
                <div class="stat-label">Upcoming Events</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon blue">👥</div>
            <div>
                <div class="stat-value">@Model.TotalParticipants</div>
                <div class="stat-label">Participants</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon amber">🏛️</div>
            <div>
                <div class="stat-value">@Model.TotalVenues</div>
                <div class="stat-label">Venues</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon teal">🎯</div>
            <div>
                <div class="stat-value">@Model.TotalActivities</div>
                <div class="stat-label">Activities</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon red">📋</div>
            <div>
                <div class="stat-value">@Model.TotalRegistrations</div>
                <div class="stat-label">Registrations</div>
                @if (Model.PendingRegistrations > 0)
                {
                    <div style="font-size:11px; color:var(--warning); margin-top:2px;">@Model.PendingRegistrations pending</div>
                }
            </div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
        <!-- Upcoming Events -->
        <div class="card" style="grid-column: span 2;">
            <div class="card-header">
                <span class="card-title">🚀 Upcoming Events</span>
                <a class="btn btn-secondary btn-sm" asp-controller="Events" asp-action="Index">View All</a>
            </div>
            <div class="card-body">
                @if (!Model.RecentEvents.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">🗓️</div>
                        <div class="empty-state-title">No upcoming events</div>
                        <p>Create your first event to get started.</p>
                    </div>
                }
                else
                {
                    <div class="events-grid">
                        @foreach (var ev in Model.RecentEvents)
                        {
                            <div class="event-card">
                                <div class="event-card-header">
                                    <span class="event-type-badge badge-@ev.EventType.ToLower()">@ev.EventType</span>
                                    <div class="event-card-title">@ev.Name</div>
                                    <div class="event-card-desc">@ev.Description</div>
                                </div>
                                <div class="event-card-body">
                                    <div class="event-meta">
                                        <div class="event-meta-item">
                                            <span class="icon">📅</span>
                                            @ev.Date.ToString("ddd, MMM dd yyyy") at @DateTime.Today.Add(ev.Time).ToString("hh:mm tt")
                                        </div>
                                        @if (ev.EventVenues.Any())
                                        {
                                            <div class="event-meta-item">
                                                <span class="icon">📍</span>
                                                @ev.EventVenues.First().Venue.Name
                                            </div>
                                        }
                                        @if (ev.MaxCapacity.HasValue)
                                        {
                                            var pct = (int)Math.Min(100, ev.Registrations.Count * 100.0 / ev.MaxCapacity.Value);
                                            <div class="event-meta-item" style="flex-direction:column; align-items:flex-start; gap:4px;">
                                                <span style="font-size:12px;">@ev.Registrations.Count / @ev.MaxCapacity spots filled</span>
                                                <div class="capacity-bar" style="width:100%">
                                                    <div class="capacity-fill" style="width:@pct%"></div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="event-card-footer">
                                    <span class="registration-count">@ev.Registrations.Count registered</span>
                                    <div style="display:flex; gap:6px;">
                                        <a class="btn btn-primary btn-sm" asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id">Details</a>
                                        <a class="btn btn-secondary btn-sm" asp-controller="Events" asp-action="Edit" asp-route-id="@ev.Id">Edit</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Recent Registrations -->
        <div class="card" style="grid-column: span 2;">
            <div class="card-header">
                <span class="card-title">📋 Recent Registrations</span>
                <a class="btn btn-secondary btn-sm" asp-controller="Registrations" asp-action="Index">View All</a>
            </div>
            @if (!Model.RecentRegistrations.Any())
            {
                <div class="card-body">
                    <div class="empty-state">
                        <div class="empty-state-icon">📝</div>
                        <div class="empty-state-title">No registrations yet</div>
                    </div>
                </div>
            }
            else
            {
                <div class="table-container" style="border:none; border-radius:0;">
                    <table>
                        <thead>
                            <tr>
                                <th>Participant</th>
                                <th>Event</th>
                                <th>Registered On</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.RecentRegistrations)
                            {
                                <tr>
                                    <td class="td-name">@r.Participant.Name</td>
                                    <td>@r.Event.Name</td>
                                    <td>@r.RegisteredAt.ToString("MMM dd, yyyy")</td>
                                    <td><span class="badge badge-@r.Status.ToString().ToLower()">@r.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
