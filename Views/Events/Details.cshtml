@model CommunityEvents.ViewModels.EventDetailsViewModel
@{
    ViewData["Title"] = Model.Event.Name;
    var ev = Model.Event;
}

<div class="page-container">
    <div style="margin-bottom:24px;">
        <a class="btn btn-secondary btn-sm" asp-action="Index">← Back to Events</a>
    </div>

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:28px;">
        <!-- Main Info -->
        <div>
            <div class="card" style="margin-bottom:24px;">
                <div class="event-card-header" style="padding:28px;">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                        <span class="event-type-badge badge-@ev.EventType.ToLower()">@ev.EventType</span>
                        <div style="display:flex; gap:8px;">
                            <a class="btn btn-secondary btn-sm" asp-action="Edit" asp-route-id="@ev.Id">✏️ Edit</a>
                            <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@ev.Id">🗑️ Delete</a>
                        </div>
                    </div>
                    <h1 style="font-size:28px; font-weight:800; margin-bottom:12px;">@ev.Name</h1>
                    <p style="color:var(--text-secondary); line-height:1.7;">@ev.Description</p>
                </div>
                <div class="card-body">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px;">
                        <div style="background:rgba(255,255,255,0.03); border:1px solid var(--border-color); border-radius:12px; padding:16px;">
                            <div style="font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--text-muted); margin-bottom:6px;">📅 Date &amp; Time</div>
                            <div style="font-size:15px; font-weight:600;">@ev.Date.ToString("dddd, MMMM dd, yyyy")</div>
                            <div style="color:var(--text-secondary); font-size:13px;">@DateTime.Today.Add(ev.Time).ToString("hh:mm tt")</div>
                        </div>
                        @if (ev.MaxCapacity.HasValue)
                        {
                            var pct = (int)Math.Min(100, ev.Registrations.Count * 100.0 / ev.MaxCapacity.Value);
                            <div style="background:rgba(255,255,255,0.03); border:1px solid var(--border-color); border-radius:12px; padding:16px;">
                                <div style="font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--text-muted); margin-bottom:6px;">🎟️ Capacity</div>
                                <div style="font-size:15px; font-weight:600;">@ev.Registrations.Count / @ev.MaxCapacity</div>
                                <div class="capacity-bar" style="margin-top:8px;">
                                    <div class="capacity-fill" style="width:@pct%"></div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Venues -->
                    @if (ev.EventVenues.Any())
                    {
                        <div class="detail-section">
                            <div class="detail-section-title">📍 Venues</div>
                            <div style="display:flex; flex-wrap:wrap; gap:10px;">
                                @foreach (var ev2 in ev.EventVenues)
                                {
                                    <div style="background:rgba(255,255,255,0.04); border:1px solid var(--border-color); border-radius:10px; padding:12px 16px;">
                                        <div style="font-weight:600; font-size:14px;">@ev2.Venue.Name</div>
                                        <div style="color:var(--text-muted); font-size:12px;">@ev2.Venue.Address, @ev2.Venue.City</div>
                                        <div style="color:var(--accent-primary); font-size:12px; margin-top:4px;">Capacity: @ev2.Venue.Capacity</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Activities -->
                    @if (ev.EventActivities.Any())
                    {
                        <div class="detail-section">
                            <div class="detail-section-title">🎯 Activities</div>
                            <div style="display:flex; flex-wrap:wrap; gap:8px;">
                                @foreach (var ea in ev.EventActivities)
                                {
                                    <div style="display:flex; align-items:center; gap:8px; background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.2); border-radius:8px; padding:8px 14px;">
                                        <span style="font-size:13px; font-weight:600; color:var(--accent-primary)">@ea.Activity.Name</span>
                                        <span class="badge badge-general" style="font-size:10px;">@ea.Activity.Type</span>
                                        @if (ea.Activity.DurationMinutes.HasValue)
                                        {
                                            <span style="font-size:11px; color:var(--text-muted)">@ea.Activity.DurationMinutes min</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Participants list -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">👥 Registered Participants (@Model.Registrations.Count)</span>
                </div>
                @if (!Model.Registrations.Any())
                {
                    <div class="card-body">
                        <div class="empty-state" style="padding:30px;">
                            <div class="empty-state-icon">👤</div>
                            <div class="empty-state-title">No participants yet</div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="table-container" style="border:none; border-radius:0;">
                        <table>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Registered</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.Registrations)
                                {
                                    <tr>
                                        <td class="td-name">@r.Participant.Name</td>
                                        <td>@r.Participant.Email</td>
                                        <td>@r.RegisteredAt.ToString("MMM dd, yyyy")</td>
                                        <td><span class="badge badge-@r.Status.ToString().ToLower()">@r.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar Actions -->
        <div>
            <div class="card" style="margin-bottom:20px;">
                <div class="card-header"><span class="card-title">🎫 Register</span></div>
                <div class="card-body">
                    <p style="font-size:13px; color:var(--text-secondary); margin-bottom:16px;">
                        Enter your registered email to sign up for this event.
                    </p>
                    <a class="btn btn-primary" style="width:100%; justify-content:center;" asp-controller="Registrations" asp-action="Register" asp-route-eventId="@ev.Id">
                        Register for Event
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <div style="font-size:12px; color:var(--text-muted); margin-bottom:8px;">Created</div>
                    <div style="font-size:14px; font-weight:500;">@ev.CreatedAt.ToString("MMM dd, yyyy")</div>
                    <div style="font-size:12px; color:var(--text-muted); margin-top:16px; margin-bottom:8px;">Status</div>
                    <span class="badge @(ev.IsActive ? "badge-confirmed" : "badge-cancelled")">
                        @(ev.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
