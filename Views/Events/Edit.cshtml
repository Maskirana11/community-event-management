@model CommunityEvents.ViewModels.EventCreateEditViewModel
@{
    ViewData["Title"] = "Edit Event";
}

<div class="page-container">
    <div style="max-width:860px; margin:0 auto;">
        <div style="margin-bottom:24px;">
            <a class="btn btn-secondary btn-sm" asp-action="Details" asp-route-id="@Model.Event.Id">← Back to Details</a>
        </div>

        <div class="page-header">
            <div class="page-header-info">
                <h1>✏️ Edit Event</h1>
                <p>Update event details, venues, and activities</p>
            </div>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Event.Id" />
            <input type="hidden" asp-for="Event.CreatedAt" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "flex")"></div>

            <div class="card" style="margin-bottom:24px;">
                <div class="card-header"><span class="card-title">📝 Event Details</span></div>
                <div class="card-body">
                    <div class="form-group">
                        <label class="form-label" asp-for="Event.Name">Event Name *</label>
                        <input asp-for="Event.Name" class="form-control" />
                        <span asp-validation-for="Event.Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Event.Description">Description *</label>
                        <textarea asp-for="Event.Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Event.Description" class="text-danger"></span>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" asp-for="Event.Date">Date *</label>
                            <input asp-for="Event.Date" class="form-control" type="date" />
                            <span asp-validation-for="Event.Date" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label" asp-for="Event.Time">Time *</label>
                            <input asp-for="Event.Time" class="form-control" type="time" />
                            <span asp-validation-for="Event.Time" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" asp-for="Event.EventType">Event Type *</label>
                            <select asp-for="Event.EventType" class="form-control">
                                <option value="General">General</option>
                                <option value="Conference">Conference</option>
                                <option value="Festival">Festival</option>
                                <option value="Competition">Competition</option>
                                <option value="Networking">Networking</option>
                                <option value="Wellness">Wellness</option>
                                <option value="Tour">Tour</option>
                                <option value="Workshop">Workshop</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label" asp-for="Event.MaxCapacity">Max Capacity</label>
                            <input asp-for="Event.MaxCapacity" class="form-control" type="number" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-check">
                            <input asp-for="Event.IsActive" class="form-check-input" type="checkbox" />
                            <span>Event is Active / Visible</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="card" style="margin-bottom:24px;">
                <div class="card-header"><span class="card-title">🏛️ Venues</span></div>
                <div class="card-body">
                    <div class="checkbox-group">
                        @foreach (var venue in Model.AllVenues)
                        {
                            <label class="checkbox-item">
                                <input type="checkbox" name="SelectedVenueIds" value="@venue.Id"
                                       @(Model.SelectedVenueIds.Contains(venue.Id) ? "checked" : "") />
                                <span>
                                    <strong>@venue.Name</strong><br />
                                    <small style="color:var(--text-muted)">@venue.City &bull; Cap: @venue.Capacity</small>
                                </span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <div class="card" style="margin-bottom:24px;">
                <div class="card-header"><span class="card-title">🎯 Activities</span></div>
                <div class="card-body">
                    <div class="checkbox-group">
                        @foreach (var activity in Model.AllActivities)
                        {
                            <label class="checkbox-item">
                                <input type="checkbox" name="SelectedActivityIds" value="@activity.Id"
                                       @(Model.SelectedActivityIds.Contains(activity.Id) ? "checked" : "") />
                                <span>
                                    <strong>@activity.Name</strong><br />
                                    <small style="color:var(--text-muted)">@activity.Type</small>
                                </span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <div style="display:flex; gap:12px; justify-content:flex-end;">
                <a class="btn btn-secondary" asp-action="Details" asp-route-id="@Model.Event.Id">Cancel</a>
                <button type="submit" class="btn btn-primary btn-lg">💾 Save Changes</button>
            </div>
        </form>
    </div>
</div>
