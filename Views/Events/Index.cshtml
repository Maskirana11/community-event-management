@model IEnumerable<CommunityEvents.Models.Event>
@using CommunityEvents.ViewModels
@{
    ViewData["Title"] = "Events";
    var filter = ViewBag.Filter as EventFilterViewModel ?? new EventFilterViewModel();
}

<div class="page-container">
    <div class="page-header">
        <div class="page-header-info">
            <h1>📅 All Events</h1>
            <p>Browse and filter community events</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">➕ Create Event</a>
    </div>

    <!-- Filter Bar -->
    <form method="get" asp-action="Index" class="filter-bar">
        <div class="filter-group">
            <label class="filter-label">Search</label>
            <input type="text" name="SearchTerm" class="form-control" placeholder="Event name..." value="@filter.SearchTerm" />
        </div>
        <div class="filter-group">
            <label class="filter-label">From Date</label>
            <input type="date" name="DateFrom" class="form-control" value="@filter.DateFrom?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="filter-group">
            <label class="filter-label">To Date</label>
            <input type="date" name="DateTo" class="form-control" value="@filter.DateTo?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="filter-group">
            <label class="filter-label">Venue</label>
            <select name="VenueId" class="form-control">
                <option value="">All Venues</option>
                @foreach (SelectListItem item in (IEnumerable<SelectListItem>)ViewBag.Venues)
                {
                    if (item.Selected)
                    {
                        <option value="@item.Value" selected="selected">@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Event Type</label>
            <select name="EventType" class="form-control">
                <option value="">All Types</option>
                @foreach (SelectListItem item in (IEnumerable<SelectListItem>)ViewBag.EventTypes)
                {
                    if (item.Text == filter.EventType)
                    {
                        <option value="@item.Text" selected="selected">@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Text">@item.Text</option>
                    }
                }
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Activity Type</label>
            <select name="ActivityType" class="form-control">
                <option value="">All Activities</option>
                @foreach (SelectListItem item in (IEnumerable<SelectListItem>)ViewBag.ActivityTypes)
                {
                    if (item.Text == filter.ActivityType)
                    {
                        <option value="@item.Text" selected="selected">@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Text">@item.Text</option>
                    }
                }
            </select>
        </div>
        <div style="display:flex; gap:8px; align-self:flex-end;">
            <button type="submit" class="btn btn-primary">🔍 Filter</button>
            <a class="btn btn-secondary" asp-action="Index">✕ Clear</a>
        </div>
    </form>

    <!-- Results Count -->
    <div style="margin-bottom:20px; color:var(--text-muted); font-size:14px;">
        Showing <strong style="color:var(--text-primary)">@Model.Count()</strong> event(s)
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🎪</div>
            <div class="empty-state-title">No events found</div>
            <p>Try adjusting your filters or create a new event.</p>
            <a class="btn btn-primary" asp-action="Create" style="margin-top:16px;">Create Event</a>
        </div>
    }
    else
    {
        <div class="events-grid">
            @foreach (var ev in Model)
            {
                var daysUntil = (ev.Date - DateTime.Today).Days;
                <div class="event-card">
                    <div class="event-card-header">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                            <span class="event-type-badge badge-@ev.EventType.ToLower()">@ev.EventType</span>
                            @if (daysUntil == 0)
                            {
                                <span class="badge badge-confirmed">Today!</span>
                            }
                            else if (daysUntil > 0 && daysUntil <= 3)
                            {
                                <span class="badge badge-pending">In @daysUntil day(s)</span>
                            }
                        </div>
                        <div class="event-card-title">@ev.Name</div>
                        <div class="event-card-desc">@ev.Description</div>
                    </div>
                    <div class="event-card-body">
                        <div class="event-meta">
                            <div class="event-meta-item">
                                <span class="icon">📅</span>
                                @ev.Date.ToString("ddd, MMM dd yyyy") &bull; @DateTime.Today.Add(ev.Time).ToString("hh:mm tt")
                            </div>
                            @if (ev.EventVenues.Any())
                            {
                                <div class="event-meta-item">
                                    <span class="icon">📍</span>
                                    @string.Join(", ", ev.EventVenues.Select(v => v.Venue.Name))
                                </div>
                            }
                            @if (ev.MaxCapacity.HasValue)
                            {
                                var pct = (int)Math.Min(100, ev.Registrations.Count * 100.0 / ev.MaxCapacity.Value);
                                <div class="event-meta-item" style="flex-direction:column; align-items:flex-start; gap:4px;">
                                    <span style="font-size:12px;">@ev.Registrations.Count / @ev.MaxCapacity capacity</span>
                                    <div class="capacity-bar" style="width:100%">
                                        <div class="capacity-fill" style="width:@pct%"></div>
                                    </div>
                                </div>
                            }
                            @if (ev.EventActivities.Any())
                            {
                                <div class="event-meta-item" style="flex-wrap:wrap; gap:4px;">
                                    <span class="icon">🎯</span>
                                    @foreach (var ea in ev.EventActivities.Take(3))
                                    {
                                        <span class="tag" style="margin:0;">@ea.Activity.Name</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="event-card-footer">
                        <span class="registration-count">@ev.Registrations.Count registered</span>
                        <div style="display:flex; gap:6px;">
                            <a class="btn btn-primary btn-sm" asp-action="Details" asp-route-id="@ev.Id">Details</a>
                            <a class="btn btn-secondary btn-sm" asp-action="Edit" asp-route-id="@ev.Id">Edit</a>
                            <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@ev.Id">Delete</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
