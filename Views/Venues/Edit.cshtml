@model CommunityEvents.Models.Venue
@{
    ViewData["Title"] = "Edit Venue";
}

<div class="page-container">
    <div style="max-width:640px; margin:0 auto;">
        <div style="margin-bottom:24px;"><a class="btn btn-secondary btn-sm" asp-action="Index">← Back to Venues</a></div>
        <div class="page-header"><div class="page-header-info"><h1>✏️ Edit Venue</h1></div></div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="card">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Name">Venue Name *</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Address">Address *</label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" asp-for="City">City *</label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label" asp-for="Capacity">Capacity *</label>
                            <input asp-for="Capacity" class="form-control" type="number" />
                            <span asp-validation-for="Capacity" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" asp-for="ContactPhone">Contact Phone</label>
                            <input asp-for="ContactPhone" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label" asp-for="ContactEmail">Contact Email</label>
                            <input asp-for="ContactEmail" class="form-control" type="email" />
                        </div>
                    </div>
                    <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:8px;">
                        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
                        <button type="submit" class="btn btn-primary">💾 Save Changes</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
