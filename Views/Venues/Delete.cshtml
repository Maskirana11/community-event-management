@model CommunityEvents.Models.Venue
@{
    ViewData["Title"] = "Delete Venue";
}

<div class="page-container">
    <div style="max-width:600px; margin:0 auto;">
        <div class="card">
            <div class="card-header" style="background:rgba(239,68,68,0.05); border-bottom-color:rgba(239,68,68,0.15);">
                <span class="card-title" style="color:var(--danger)">🗑️ Delete Venue</span>
            </div>
            <div class="card-body">
                <div class="alert alert-danger">⚠️ This will remove the venue from all associated events.</div>
                <h2 style="font-size:20px; font-weight:700; margin-bottom:8px;">@Model.Name</h2>
                <p style="color:var(--text-secondary);">📍 @Model.Address, @Model.City &bull; Capacity: @Model.Capacity</p>
                <p style="color:var(--text-muted); font-size:13px; margin-top:8px;">Associated with @Model.EventVenues.Count event(s).</p>
                <form asp-action="Delete" method="post" style="display:flex; gap:12px; justify-content:flex-end; margin-top:24px;">
                    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
                    <button type="submit" class="btn btn-danger">🗑️ Yes, Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
