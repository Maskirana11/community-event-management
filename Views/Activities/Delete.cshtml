@model CommunityEvents.Models.Activity
@{
    ViewData["Title"] = "Delete Activity";
}
<div class="page-container">
    <div style="max-width:560px; margin:0 auto;">
        <div class="card">
            <div class="card-header" style="background:rgba(239,68,68,0.05);">
                <span class="card-title" style="color:var(--danger)">🗑️ Delete Activity</span>
            </div>
            <div class="card-body">
                <div class="alert alert-danger">⚠️ This will remove the activity from all events.</div>
                <h2 style="font-size:20px; font-weight:700; margin-bottom:8px;">@Model.Name</h2>
                <p style="color:var(--text-secondary);">@Model.Type @(Model.DurationMinutes.HasValue ? $"• {Model.DurationMinutes} min" : "")</p>
                <form asp-action="Delete" method="post" style="display:flex; gap:12px; justify-content:flex-end; margin-top:24px;">
                    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
                    <button type="submit" class="btn btn-danger">🗑️ Yes, Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
