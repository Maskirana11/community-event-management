@model CommunityEvents.Models.Activity
@{
    ViewData["Title"] = "Activity Details";
}
<div class="page-container">
    <div style="margin-bottom:24px;"><a class="btn btn-secondary btn-sm" asp-action="Index">← Back</a></div>
    <div class="page-header">
        <div class="page-header-info">
            <h1>@Model.Name</h1>
            <p>@Model.Type @(Model.DurationMinutes.HasValue ? $"• {Model.DurationMinutes} minutes" : "")</p>
        </div>
        <div style="display:flex;gap:8px;">
            <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">✏️ Edit</a>
            <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id">🗑️ Delete</a>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p style="color:var(--text-secondary); margin-bottom:24px;">@Model.Description</p>
            }
            @if (Model.EventActivities.Any())
            {
                <div style="font-size:13px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:12px;">Used in Events</div>
                @foreach (var ea in Model.EventActivities)
                {
                    <a asp-controller="Events" asp-action="Details" asp-route-id="@ea.EventId"
                       style="display:block; padding:10px 14px; background:rgba(255,255,255,0.03); border:1px solid var(--border-color); border-radius:8px; text-decoration:none; color:var(--text-primary); margin-bottom:8px;">
                        @ea.Event.Name — <span style="color:var(--text-muted); font-size:13px;">@ea.Event.Date.ToString("MMM dd, yyyy")</span>
                    </a>
                }
            }
        </div>
    </div>
</div>
