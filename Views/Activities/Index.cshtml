@model IEnumerable<CommunityEvents.Models.Activity>
@{
    ViewData["Title"] = "Activities";
}

<div class="page-container">
    <div class="page-header">
        <div class="page-header-info">
            <h1>🎯 Activities</h1>
            <p>Manage workshops, talks, games, and other activities</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">➕ Add Activity</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🎭</div>
            <div class="empty-state-title">No activities yet</div>
            <a class="btn btn-primary" asp-action="Create" style="margin-top:16px;">Add First Activity</a>
        </div>
    }
    else
    {
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Activity</th>
                        <th>Type</th>
                        <th>Duration</th>
                        <th>Events</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var activity in Model)
                    {
                        <tr>
                            <td>
                                <div class="td-name">@activity.Name</div>
                                @if (!string.IsNullOrEmpty(activity.Description))
                                {
                                    <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">@(activity.Description.Length > 60 ? activity.Description[..60] + "…" : activity.Description)</div>
                                }
                            </td>
                            <td><span class="badge badge-general">@activity.Type</span></td>
                            <td>@(activity.DurationMinutes.HasValue ? $"{activity.DurationMinutes} min" : "—")</td>
                            <td>@activity.EventActivities.Count</td>
                            <td>
                                <div style="display:flex; gap:6px;">
                                    <a class="btn btn-secondary btn-sm" asp-action="Details" asp-route-id="@activity.Id">Details</a>
                                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@activity.Id">Edit</a>
                                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@activity.Id">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
