@model CommunityEvents.Models.Activity
@{
    ViewData["Title"] = "Edit Activity";
}

<div class="page-container">
    <div style="max-width:600px; margin:0 auto;">
        <div style="margin-bottom:24px;"><a class="btn btn-secondary btn-sm" asp-action="Index">← Back to Activities</a></div>
        <div class="page-header"><div class="page-header-info"><h1>✏️ Edit Activity</h1></div></div>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="card">
                <div class="card-body">
                    <div class="form-group">
                        <label class="form-label" asp-for="Name">Activity Name *</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" asp-for="Type">Type *</label>
                            <select asp-for="Type" class="form-control">
                                <option value="Workshop">Workshop</option>
                                <option value="Talk">Talk</option>
                                <option value="Game">Game</option>
                                <option value="Networking">Networking</option>
                                <option value="Tour">Tour</option>
                                <option value="Exhibition">Exhibition</option>
                                <option value="Competition">Competition</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label" asp-for="DurationMinutes">Duration (minutes)</label>
                            <input asp-for="DurationMinutes" class="form-control" type="number" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div style="display:flex; gap:12px; justify-content:flex-end;">
                        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
                        <button type="submit" class="btn btn-primary">💾 Save Changes</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
