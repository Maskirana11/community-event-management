@model CommunityEvents.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register for Event";
}

<div class="page-container">
    <div style="max-width:560px; margin:0 auto;">
        <div style="margin-bottom:24px;">
            <a class="btn btn-secondary btn-sm" asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId">← Back to Event</a>
        </div>

        <div class="page-header">
            <div class="page-header-info">
                <h1>🎫 Register for Event</h1>
                <p>@Model.EventName</p>
            </div>
        </div>

        <form asp-action="Register" method="post">
            <input type="hidden" asp-for="EventId" />
            <input type="hidden" asp-for="EventName" />

            <div class="card">
                <div class="card-header"><span class="card-title">Your Details</span></div>
                <div class="card-body">
                    <div class="alert alert-info" style="margin-bottom:20px;">
                        💡 Use the email address you registered with as a participant. If you're new, <a asp-controller="Participants" asp-action="Create" style="color:var(--accent-primary)">register as a participant</a> first.
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Email">Your Email Address *</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="your@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Notes">Notes (optional)</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Any special requirements or questions?"></textarea>
                    </div>

                    <div style="display:flex; gap:12px; justify-content:flex-end;">
                        <a class="btn btn-secondary" asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId">Cancel</a>
                        <button type="submit" class="btn btn-primary btn-lg">🎉 Confirm Registration</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
