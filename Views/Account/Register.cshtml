@model CommunityEvents.ViewModels.RegisterUserViewModel
@{
    ViewData["Title"] = "Register";
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

<style>
    .register-page-wrapper {
        min-height: calc(100vh - 57px);
        display: flex;
        align-items: stretch;
        padding: 0;
        margin: 0;
        margin-top: -20px;
    }

    .register-wrap {
        display: flex;
        width: 100%;
        height: calc(100vh - 57px + 20px);
        border-radius: 0;
        box-shadow: none;
        font-family: 'Inter', sans-serif;
    }

    /* ── Left panel ── */
    .register-left {
        background: #0F172A;
        flex: 1;
        padding: 52px 44px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

    .orb {
        position: absolute;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle at 40% 40%, #6366F1 0%, #312e81 55%, transparent 80%);
        opacity: 0.45;
        top: -100px;
        right: -100px;
    }

    .orb2 {
        position: absolute;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: radial-gradient(circle at 60% 60%, #818cf8 0%, #3730a3 60%, transparent 80%);
        opacity: 0.2;
        bottom: -40px;
        left: -60px;
    }

    .left-tag {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        color: #818cf8;
        text-transform: uppercase;
        margin-bottom: 24px;
        position: relative;
        z-index: 1;
    }

    .left-headline {
        font-family: 'Fraunces', serif;
        font-size: 42px;
        font-weight: 600;
        color: #f8fafc;
        line-height: 1.2;
        margin: 0 0 20px;
        position: relative;
        z-index: 1;
    }

    .left-sub {
        font-size: 15px;
        color: #94a3b8;
        line-height: 1.7;
        margin: 0;
        max-width: 280px;
        position: relative;
        z-index: 1;
    }

    .left-features {
        margin-top: 40px;
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .left-feature-item {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .feature-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: rgba(99, 102, 241, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .feature-icon svg {
        width: 16px;
        height: 16px;
        stroke: #818cf8;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .feature-text {
        font-size: 13px;
        color: #94a3b8;
        line-height: 1.4;
    }

    .left-dots {
        display: flex;
        gap: 8px;
        margin-top: 40px;
        position: relative;
        z-index: 1;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #334155;
    }

    .dot.active {
        background: #6366F1;
        width: 24px;
        border-radius: 4px;
    }

    /* ── Right panel ── */
    .register-right {
        background: #ffffff;
        flex: 1;
        padding: 0 64px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        overflow-y: auto;
    }

    .form-title {
        font-family: 'Fraunces', serif;
        font-size: 30px;
        font-weight: 600;
        color: #0F172A;
        margin: 0 0 8px;
    }

    .form-sub {
        font-size: 14px;
        color: #64748b;
        margin: 0 0 22px;
    }

    .register-field {
        margin-bottom: 20px;
    }

    .register-field label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #475569;
        margin-bottom: 7px;
    }

    .register-field .form-control {
        width: 100%;
        height: 46px;
        padding: 0 16px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        border-radius: 8px;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
        color: #0f172a;
        box-sizing: border-box;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .register-field .form-control:focus {
        border-color: #6366F1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
        outline: none;
        background: #fff;
    }

    .btn-indigo {
        width: 100%;
        height: 50px;
        background: #6366F1;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 500;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        margin-top: 8px;
        margin-bottom: 20px;
        letter-spacing: 0.3px;
        transition: background 0.15s;
    }

    .btn-indigo:hover {
        background: #4f46e5;
    }

    .btn-indigo:active {
        background: #4338ca;
        transform: scale(0.99);
    }

    .login-line {
        font-size: 13px;
        color: #64748b;
        text-align: center;
    }

    .login-line a {
        color: #6366F1;
        font-weight: 500;
        text-decoration: none;
    }

    .login-line a:hover {
        text-decoration: underline;
    }

    @@media (max-width: 640px) {
        .register-left { display: none; }
        .register-right { padding: 36px 28px; }
    }
</style>

<div class="register-page-wrapper">
    <div class="register-wrap">

        <!-- Left branding panel -->
        <div class="register-left">
            <div class="orb"></div>
            <div class="orb2"></div>
            <div>
                <div class="left-tag">Community Events</div>
                <p class="left-headline">Join your<br />community<br />today.</p>
                <p class="left-sub">Create an account and start discovering events that bring people together.</p>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="register-right">
            <p class="form-title">Create an account</p>
            <p class="form-sub">Fill in your details to get started.</p>

            <form asp-action="Register">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="register-field">
                    <label asp-for="Name"></label>
                    <input asp-for="Name" class="form-control" placeholder="Your full name" />
                    <span asp-validation-for="Name" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="register-field">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="register-field">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="register-field">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:12px;"></span>
                </div>

                <button type="submit" class="btn-indigo">Create account</button>

                <div class="login-line">
                    Already have an account? <a asp-action="Login">Log in</a>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}