@model IEnumerable<CommunityEvents.Models.Participant>
@{
    ViewData["Title"] = "Participants";
}

<div class="page-container">
    <div class="page-header">
        <div class="page-header-info">
            <h1>👥 Participants</h1>
            <p>Manage registered community members</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">➕ Add Participant</a>
    </div>

    <!-- Search -->
    <form method="get" asp-action="Index" style="margin-bottom:24px; display:flex; gap:10px;">
        <input type="text" name="search" class="form-control" placeholder="Search by name or email..." value="@ViewBag.Search" style="max-width:360px;" />
        <button type="submit" class="btn btn-primary">🔍 Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search?.ToString()))
        {
            <a class="btn btn-secondary" asp-action="Index">✕ Clear</a>
        }
    </form>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">👤</div>
            <div class="empty-state-title">No participants found</div>
            <a class="btn btn-primary" asp-action="Create" style="margin-top:16px;">Add Participant</a>
        </div>
    }
    else
    {
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Organization</th>
                        <th>Registrations</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="td-name">@p.Name</td>
                            <td>@p.Email</td>
                            <td>@(p.Phone ?? "—")</td>
                            <td>@(p.Organization ?? "—")</td>
                            <td>
                                <span style="background:rgba(99,102,241,0.12); color:var(--accent-primary); padding:2px 10px; border-radius:12px; font-size:12px; font-weight:600;">
                                    @p.Registrations.Count
                                </span>
                            </td>
                            <td>@p.RegisteredAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div style="display:flex; gap:6px;">
                                    <a class="btn btn-secondary btn-sm" asp-action="Details" asp-route-id="@p.Id">Details</a>
                                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@p.Id">Edit</a>
                                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@p.Id">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
